# DPG deployment variables template
# Do not commit real secrets. Keep production values in Render/Netlify dashboards or a secure vault.

# Backend
DATABASE_URL=postgresql://<dpg-db-user>:<password>@<host>/<database>?sslmode=require
DIRECT_DATABASE_URL=postgresql://<dpg-db-user>:<password>@<direct-host>/<database>?sslmode=require
CACHE_DATABASE_URL=
QUEUE_DATABASE_URL=
REDIS_URL=
SECRET_KEY_BASE=<generate-with-api-bin-rails-secret>
RAILS_MASTER_KEY=
RAILS_ENV=production
FRONTEND_URL=https://<dpg-frontend-domain>
ALLOWED_ORIGINS=https://<dpg-frontend-domain>
CLERK_SECRET_KEY=sk_live_<dpg-clerk-secret>
CLERK_PUBLISHABLE_KEY=pk_live_<dpg-clerk-publishable>
CLERK_JWT_AUDIENCE=
AUTO_PROVISION_USERS=false
BOOTSTRAP_ADMIN_EMAILS=<initial-admin-email@example.com>
BOOTSTRAP_ADMIN_ROLE=campaign_admin
CLICKSEND_USERNAME=<optional-dpg-sms-username>
CLICKSEND_API_KEY=<optional-dpg-sms-api-key>
CLICKSEND_SENDER_ID=DPG
DPG_CLICKSEND_SENDER_ID=DPG
DPG_LIVE_OUTREACH_ENABLED=false
RESEND_API_KEY=<optional-dpg-resend-key>
RESEND_FROM_EMAIL=<optional-from-email>
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
OPENROUTER_API_KEY=
RAILS_LOG_LEVEL=info

# Frontend
VITE_API_URL=https://<dpg-api-domain>
VITE_CLERK_PUBLISHABLE_KEY=pk_live_<dpg-clerk-publishable>
VITE_PUBLIC_POSTHOG_KEY=<optional-dpg-posthog-key>
VITE_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
VITE_ENABLE_ANALYTICS_IN_DEV=false

# Netlify deploy helper
NETLIFY_SITE_ID=<dpg-netlify-site-id>
NETLIFY_AUTH_TOKEN=<netlify-auth-token>
